---
---
<!doctype html>
<html lang="en" class="scroll-smooth dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Luminous - Social Reach Automated</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #030303;
    }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background-color: var(--bg);
      color: white;
      overflow-x: hidden;
    }

    /* Subtle grid background */
    .grid-bg {
      background-image:
        linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    /* Stars background */
    .stars {
      background-image:
        radial-gradient(1px 1px at 15px 25px, rgba(255,255,255,0.4), transparent),
        radial-gradient(1px 1px at 80px 250px, rgba(255,255,255,0.2), transparent),
        radial-gradient(1.5px 1.5px at 200px 80px, rgba(255,255,255,0.5), transparent),
        radial-gradient(1px 1px at 320px 300px, rgba(255,255,255,0.2), transparent),
        radial-gradient(1px 1px at 450px 120px, rgba(255,255,255,0.6), transparent),
        radial-gradient(1.5px 1.5px at 550px 350px, rgba(255,255,255,0.3), transparent),
        radial-gradient(1px 1px at 700px 90px, rgba(255,255,255,0.4), transparent),
        radial-gradient(1px 1px at 820px 200px, rgba(255,255,255,0.7), transparent),
        radial-gradient(1px 1px at 950px 50px, rgba(255,255,255,0.2), transparent),
        radial-gradient(1.5px 1.5px at 1100px 420px, rgba(255,255,255,0.5), transparent),
        radial-gradient(1px 1px at 1250px 180px, rgba(255,255,255,0.4), transparent),
        radial-gradient(1px 1px at 1380px 80px, rgba(255,255,255,0.3), transparent);
      background-size: 1440px 500px;
      background-repeat: repeat;
      opacity: 0.5;
    }

    /* Center light beam & distortion */
    .center-beam {
      position: absolute;
      left: 50%;
      top: -20%;
      height: 140%;
      width: 2px;
      transform: translateX(-50%);
      background: #fff;
      box-shadow: 
        0 0 100px 20px #ffae00,
        0 0 200px 60px #ff5100,
        0 0 300px 120px rgba(255, 68, 0, 0.4);
      border-radius: 100%;
      z-index: 0;
    }

    /* Noise/Textured overlay on the beam for that "particle/dust" feel */
    .beam-dust {
      position: absolute;
      left: 45%;
      top: 0;
      width: 10%;
      height: 100%;
      background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)" opacity="0.3" /%3E%3C/svg%3E');
      mix-blend-mode: color-dodge;
      opacity: 0.6;
      border-radius: 100%;
      mask-image: radial-gradient(ellipse at center, black 10%, transparent 60%);
      -webkit-mask-image: radial-gradient(ellipse at center, black 10%, transparent 60%);
      pointer-events: none;
      z-index: 1;
    }

    .bottom-flare {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 80vw;
      height: 30vh;
      background: radial-gradient(ellipse at bottom, rgba(255, 230, 0, 0.8) 0%, rgba(255, 50, 0, 0.4) 30%, transparent 70%);
      z-index: 1;
      filter: blur(40px);
      pointer-events: none;
    }

    .card-border-gradient {
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.4s ease;
    }
    
    .card-border-gradient:hover {
      border-color: rgba(255, 136, 0, 0.4);
      box-shadow: 0 0 40px rgba(255, 110, 0, 0.2);
    }
    
    /* Chart Gradient */
    .chart-fill {
      fill: url(#orangeGradient);
    }

    /* Buttons */
    .btn-gradient-explore {
      background: linear-gradient(90deg, #ffc56e 0%, #ff9d2a 50%, #f77c15 100%);
      box-shadow: 0 0 30px rgba(255, 136, 0, 0.3);
      transition: all 0.3s ease;
    }
    .btn-gradient-explore:hover {
      box-shadow: 0 0 40px rgba(255, 136, 0, 0.5);
      filter: brightness(1.1);
    }
    
    .btn-gradient-analyze {
      background: linear-gradient(90deg, #ed7c27 0%, #d6550b 100%);
      transition: all 0.3s ease;
    }
    .btn-gradient-analyze:hover {
      filter: brightness(1.15);
      box-shadow: 0 0 20px rgba(237, 124, 39, 0.4);
    }

    /* Animations */
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .float-anim {
      animation: float 8s ease-in-out infinite;
    }
  </style>
</head>
<body class="antialiased">

  <main class="relative min-h-screen flex items-center overflow-hidden pt-20 pb-20 md:pt-0 md:pb-0">
    
    <!-- Background Elements -->
    <div class="fixed inset-0 grid-bg z-[-3]"></div>
    <div class="fixed inset-0 stars z-[-2]"></div>
    
    <!-- Core Visual Effect -->
    <div class="absolute inset-0 flex justify-center z-[-1] overflow-hidden">
      <div class="center-beam"></div>
      <div class="beam-dust"></div>
      <div class="bottom-flare"></div>
      <canvas id="plasma-sparks" class="absolute inset-0 w-full h-full pointer-events-none z-10 mix-blend-screen"></canvas>
    </div>

    <!-- Content Container -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12 grid lg:grid-cols-[1.2fr_1fr] gap-12 lg:gap-8 items-center">
      
      <!-- Left Content -->
      <div class="max-w-xl mx-auto lg:mx-0">
        <!-- Top Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-white/5 border border-white/10 backdrop-blur-md mb-8">
          <svg class="w-4 h-4 text-orange-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <span class="text-xs font-semibold text-gray-300 tracking-wide">Social Growth, Autopilot Mode</span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl lg:text-[4.7rem] font-bold tracking-tight leading-[1.05] text-white mb-6">
          SOCIAL REACH<br/>
          AUTOMATED<br/>
          GROWTH VIRAL<br/>
          RESULTS
        </h1>

        <!-- Paragraph -->
        <p class="text-[17px] text-gray-400 leading-relaxed mb-10 max-w-[90%]">
          Stop guessing what works. Luminous analyzes trends and automates our content strategy for maximum engagement across every platform.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <button class="btn-gradient-explore text-[#4a2400] font-bold px-8 py-3.5 rounded-full text-[15px]">
            Explore design
          </button>
          <button class="bg-white hover:bg-gray-100 text-black font-bold px-8 py-3.5 rounded-full text-[15px] transition-colors">
            View Features
          </button>
        </div>
      </div>

      <!-- Right Content (Widget Card) -->
      <div class="w-full flex justify-center lg:justify-end">
        <div class="relative w-full max-w-[420px] float-anim">
          
          <!-- Outer glow for the widget -->
          <div class="absolute inset-0 bg-orange-600/10 blur-[60px] rounded-[2rem]"></div>
          
          <!-- Card Body -->
          <div class="relative bg-black/60 backdrop-blur-2xl rounded-[2rem] p-8 card-border-gradient overflow-hidden">
            
            <!-- Shiny top border highlight -->
            <div class="absolute top-0 left-[10%] right-[10%] h-[1px] bg-gradient-to-r from-transparent via-orange-400/60 to-transparent"></div>

            <!-- Card Inner Header -->
            <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded border border-white/5 bg-white/5 mb-8">
              <span class="w-1.5 h-1.5 rounded-full bg-orange-500 shadow-[0_0_8px_rgba(249,115,22,0.8)]"></span>
              <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">VIRAL RESULT</span>
            </div>

            <h3 class="text-[22px] font-semibold text-white mb-1.5">Growth Velocity</h3>
            <p class="text-sm text-gray-400 mb-8">Automated engagement hitting viral peaks.</p>

            <!-- Stats -->
            <div class="flex items-end gap-3 mb-8">
              <div class="text-white flex items-baseline">
                <span class="text-[44px] font-light leading-none tracking-tight">+842</span>
                <span class="text-3xl font-light text-gray-300 ml-0.5">%</span>
              </div>
              <div class="flex items-center gap-1.5 px-2 py-1 bg-orange-500/10 border border-orange-500/20 rounded text-orange-400 text-[11px] font-semibold mb-2">
                <span>↑</span> vs last week
              </div>
            </div>

            <!-- Chart Box -->
            <div class="w-full h-[70px] relative mb-8">
              <svg width="100%" height="100%" viewBox="0 0 300 70" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="orangeGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#f97316" stop-opacity="0.3"></stop>
                    <stop offset="100%" stop-color="#f97316" stop-opacity="0"></stop>
                  </linearGradient>
                  <!-- Soft line glow -->
                  <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feComposite in="SourceGraphic" in2="blur" operator="over" />
                  </filter>
                </defs>
                <!-- Filled Area -->
                <path d="M 0 65 C 50 65, 100 50, 150 45 C 200 40, 250 25, 300 10 L 300 70 L 0 70 Z" class="chart-fill"></path>
                <!-- Line -->
                <path d="M 0 65 C 50 65, 100 50, 150 45 C 200 40, 250 25, 300 10" fill="none" stroke="#f97316" stroke-width="2.5" filter="url(#glow)"></path>
                <!-- End Dot -->
                <circle cx="300" cy="10" r="4" fill="#fff" stroke="#f97316" stroke-width="2" filter="url(#glow)"></circle>
              </svg>
            </div>

            <!-- Action Button -->
            <button class="w-full btn-gradient-analyze text-white font-semibold text-[15px] py-4 rounded-xl mb-8 flex justify-center items-center">
              Analyze Trends
            </button>

            <!-- Bottom Stats -->
            <div class="space-y-6">
              <!-- Impressions -->
              <div class="flex items-center justify-between text-[13px]">
                <div class="flex items-center gap-2 text-gray-400 font-medium">
                  <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.522 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.478 0-8.268-2.943-9.542-7z" />
                  </svg>
                  Total Impressions
                </div>
                <div class="text-white font-semibold">2.4M</div>
              </div>

              <!-- Divider -->
              <div class="flex items-center gap-4">
                <div class="flex-1 h-px bg-white/5"></div>
                <div class="text-[10px] font-bold text-gray-500 tracking-[0.2em] uppercase">AI POWERED SCALE</div>
                <div class="flex-1 h-px bg-white/5"></div>
              </div>

              <!-- Auto Optimization -->
              <div class="flex items-center justify-between text-[13px] text-gray-300 font-medium">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l2.4 7.6H22l-6.2 4.8 2.3 7.2-6.1-4.8-6.1 4.8 2.3-7.2L2 9.6h7.6z"/>
                  </svg>
                  Auto-Optimization
                </div>
                <!-- Optional status dot or icon here if needed -->
                <div></div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </main>
  
  <script>
    (function () {
      const canvas = document.getElementById('plasma-sparks');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      let W = 0, H = 0, cx = 0;
      let particles = [];
      const COLORS = ['#ffed4a', '#ffae00', '#ff5100', '#ffffff', '#ffd166'];

      function resize() {
        const rect = canvas.parentElement.getBoundingClientRect();
        W = canvas.width = rect.width;
        H = canvas.height = rect.height;
        cx = W / 2;
      }

      function createParticle() {
        // Sparks originate strictly around the central pillar
        const distance = Math.pow(Math.random(), 2) * 60; // Bias towards center
        const sign = Math.random() > 0.5 ? 1 : -1;
        const x = cx + sign * distance;
        
        // Start anywhere above the screen or upper half for continuous flow
        const y = -20 - Math.random() * 50;
        
        // Initial velocities
        const vx = (Math.random() - 0.5) * 0.8; 
        const vy = 3 + Math.random() * 6; // Fast falling speed
        const size = 0.5 + Math.random() * 3;
        
        particles.push({
          x, y, vx, vy, size,
          life: 0,
          maxLife: 200 + Math.random() * 100, // Long life so they reach bottom
          color: COLORS[Math.floor(Math.random() * COLORS.length)]
        });
      }

      window.addEventListener('resize', resize);
      resize();

      // Pre-fill the screen with particles
      for (let i = 0; i < 200; i++) {
         createParticle();
         // Fast forward particle life to distribute them across the screen
         const steps = Math.random() * particles[particles.length - 1].maxLife * 0.8;
         for (let s = 0; s < steps; s++) {
            const p = particles[particles.length - 1];
            p.x += p.vx;
            p.y += p.vy;
         }
      }

      function render() {
        ctx.clearRect(0, 0, W, H);

        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          
          p.vy += 0.08; // Gravity
          
          // Meandering effect mimicking plasma instability
          p.vx += Math.sin((p.y * 0.01) + p.life) * 0.04;
          
          // Spread out rapidly when reaching the bottom floor (flare area)
          if (p.y > H * 0.7) {
            const spread = p.x > cx ? 1 : -1;
            p.vx += spread * 0.15;
          }

          // Friction limits speed
          p.vx *= 0.98;

          const prevX = p.x;
          const prevY = p.y;
          p.x += p.vx;
          p.y += p.vy;
          p.life++;

          if (p.y > H + 50 || p.life > p.maxLife || p.x < -50 || p.x > W + 50) {
            particles.splice(i, 1);
            createParticle();
            continue;
          }

          // Calculate visual properties
          const alphaFadeIn = Math.min(1, p.life / 20); // Fade in
          const alphaFadeOut = Math.max(0, 1 - (p.y / (H + 50))); // Fade out as it leaves bottom
          let alpha = Math.min(alphaFadeIn, alphaFadeOut);

          // Render trail
          ctx.beginPath();
          ctx.lineCap = 'round';
          ctx.lineWidth = p.size;
          ctx.strokeStyle = p.color;
          ctx.globalAlpha = alpha;
          
          // Adds intense glow to larger sparks
          if (p.size > 2) {
             ctx.shadowBlur = 10;
             ctx.shadowColor = p.color;
          } else {
             ctx.shadowBlur = 0;
          }

          ctx.moveTo(prevX, prevY);
          const stretch = p.vy * 1.5;
          ctx.lineTo(p.x, p.y - stretch);
          ctx.stroke();

          // Render hot core
          ctx.beginPath();
          ctx.fillStyle = '#ffffff';
          ctx.globalAlpha = alpha;
          ctx.shadowBlur = 0;
          ctx.arc(p.x, p.y, p.size * 0.3, 0, Math.PI * 2);
          ctx.fill();
        }

        requestAnimationFrame(render);
      }
      
      requestAnimationFrame(render);
    })();
  </script>
</body>
</html>
